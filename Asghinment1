Ans:
import java.util.Scanner;

class FindGCD
{
    void calc(int a, int b)
    {
        int gcd = 1;

        for(int i = 1; i <= a && i <= b; i++)
        {
            if(a % i == 0 && b % i == 0)
            {
                gcd = i;
            }
        }

        System.out.println("GCD = " + gcd);
    }
}

