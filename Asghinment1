import java.util.Scanner;

class CheckPalindrome
{
    void check(int num)
    {
        int rev = 0, temp = num;

        while(num > 0)
        {
            int d = num % 10;
            rev = rev * 10 + d;
            num = num / 10;
        }

        if(temp == rev)
            System.out.println("Palindrome");
        else
            System.out.println("Not Palindrome");
    }
}

class upDemo
